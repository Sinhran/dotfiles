{
    "label" : "lock",
    "action" : "swaylock || betterlockscreen -l || hyprlock",
    "text" : "lock",
    "keybind" : "l"
}
{
    "label" : "hibernate",
    "action" : "zzz -H || echo 'Hibernate not available'",
    "text" : "downloading",
    "keybind" : "h"
}
{
    "label" : "logout",
    "action" : "hyprctl clients -j | jq -r '.[].pid' | xargs kill; pkill Hyprland || pkill sway || pkill niri || pkill -u $USER",
    "text" : "logout",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "hyprctl clients -j | jq -r '.[].pid' | xargs kill; openrc-shutdown --poweroff now",
    "text" : "power_settings_new",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "zzz || echo 'Suspend not available'",
    "text" : "bedtime",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "hyprctl clients -j | jq -r '.[].pid' | xargs kill; openrc-shutdown --reboot now",
    "text" : "restart_alt",
    "keybind" : "r"
}
